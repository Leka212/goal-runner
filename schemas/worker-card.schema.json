{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://goal-protocol.local/schemas/worker-card.schema.json",
  "type": "object",
  "required": [
    "id",
    "role",
    "engine",
    "workspace",
    "objective",
    "files_or_systems",
    "non_goals",
    "tools_allowed",
    "gates",
    "acceptance",
    "output_contract",
    "timeout_seconds"
  ],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "role": { "type": "string", "minLength": 1 },
    "engine": { "type": "string", "minLength": 1 },
    "workspace": { "type": "string", "minLength": 1 },
    "objective": { "type": "string", "minLength": 1 },
    "files_or_systems": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "non_goals": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "tools_allowed": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "gates": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "acceptance": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "output_contract": {
      "type": "object",
      "required": ["required_sections"],
      "additionalProperties": false,
      "properties": {
        "required_sections": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "timeout_seconds": { "type": "integer", "minimum": 1 }
  }
}
